# Telegram bot token (required)
BOT_TOKEN=

# Protected developer Telegram ID (required)
PROTECTED_DEV_TG_ID=378881880

# SQLite database path (required)
DB_PATH=/opt/bots/barbershop-bot/app/db.sqlite3

# Optional app secret for signed payloads (if empty, BOT_TOKEN is used)
APP_SECRET_KEY=

# White-label branding (single place for business identity)
BUSINESS_NAME=Барбершоп
SUPPORT_CONTACT=@XXX
BUSINESS_ADDRESS=Саратов, улица Пушкина, 1
BUSINESS_PHONE=+7 (8452) 00-00-00

# Backward-compatible aliases (optional)
CONTACT_ADDRESS=
BOOKING_PHONE=

# Review links used in feedback buttons
YANDEX_REVIEW_URL=https://yandex.ru/maps/
TWO_GIS_REVIEW_URL=https://2gis.ru/

# Optional staff group chat ID for reminders
STAFF_GROUP_ID=0

# YClients integration
YCLIENTS_PARTNER_TOKEN=
YCLIENTS_USER_TOKEN=
YCLIENTS_COMPANY_ID=
YCLIENTS_BASE_URL=https://api.yclients.com
BARBERSHOP_PHOTO_FILE_ID=

# Runtime environment (dev/prod)
APP_ENV=prod

# Python logging level
LOG_LEVEL=INFO

# Optional status hint for systemd unit name
SYSTEMD_UNIT=telegram-bot@<name>.service
